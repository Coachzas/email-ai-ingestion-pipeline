generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Email {
  id          String       @id @default(uuid())
  imapUid     Int          @unique
  fromEmail   String
  subject     String?
  bodyText    String?
  receivedAt  DateTime
  createdAt   DateTime     @default(now())
  accountId   String?
  attachments Attachment[]
  account     EmailAccount? @relation(fields: [accountId], references: [id])
}

model EmailAccount {
  id         String        @id @default(uuid())
  name       String
  host       String
  port       Int
  secure     Boolean       @default(true)
  username   String
  password   String
  status     AccountStatus @default(ACTIVE)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  isSelected Boolean       @default(false)
  emails     Email[]
}

model BatchScheduler {
  id           String         @id @default(uuid())
  name         String
  batchSize    Int
  scheduleType ScheduleType
  customHour   Int?
  customMinute Int?
  startDate    DateTime
  endDate      DateTime?
  isActive     Boolean        @default(true)
  lastRunAt    DateTime?
  nextRunAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  batchRuns    BatchRun[]
}

model BatchRun {
  id              String         @id @default(uuid())
  schedulerId     String
  batchNumber     Int
  status          BatchRunStatus @default(PENDING)
  emailsProcessed Int            @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  errorMessage    String?
  createdAt       DateTime       @default(now())
  scheduler       BatchScheduler @relation(fields: [schedulerId], references: [id])
}

model Attachment {
  id            String     @id @default(uuid())
  emailId       String
  fileName      String
  fileType      String
  filePath      String
  size          Int?
  extractedText String?
  ocrStatus     OcrStatus?
  createdAt     DateTime   @default(now())
  email         Email      @relation(fields: [emailId], references: [id])
}

enum OcrStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  ERROR
}

enum ScheduleType {
  DAILY
  HOURLY
  CUSTOM
}

enum BatchRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
