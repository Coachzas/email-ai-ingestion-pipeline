generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Email {
  id          String       @id @default(uuid())
  imapUid     Int          @unique
  fromEmail   String
  subject     String?
  bodyText    String?
  receivedAt  DateTime
  createdAt   DateTime     @default(now())
  accountId   String?
  userId      String?      // Add user isolation
  attachments Attachment[]
  account     EmailAccount? @relation(fields: [accountId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])
}

model EmailAccount {
  id         String        @id @default(uuid())
  name       String
  host       String
  port       Int
  secure     Boolean       @default(true)
  username   String
  password   String
  status     AccountStatus @default(ACTIVE)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  isSelected Boolean       @default(false)
  userId     String?        // Add user isolation
  emails     Email[]
  user       User?         @relation(fields: [userId], references: [id])
  batchSchedulers BatchScheduler[]
}

model BatchScheduler {
  id           String         @id @default(uuid())
  name         String
  batchSize    Int
  scheduleType ScheduleType
  customHour   Int?
  customMinute Int?
  startDate    DateTime
  endDate      DateTime?
  isActive     Boolean        @default(true)
  lastRunAt    DateTime?
  nextRunAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  userId       String?        // Add user isolation
  selectedDays String?         // JSON array of selected days for custom schedule
  timeSlots    String?         // JSON array of time slots for custom schedule (legacy support)
  dayTimeSlots String?         // JSON object with per-day time slots: {"MONDAY": [{hour: 9, minute: 0}], "TUESDAY": [...]}
  batchRuns    BatchRun[]
  account      EmailAccount?   @relation(fields: [accountId], references: [id])
  accountId    String?        // Link to email account
  user         User?           @relation(fields: [userId], references: [id])
}

model BatchRun {
  id              String         @id @default(uuid())
  schedulerId     String
  batchNumber     Int
  status          BatchRunStatus @default(PENDING)
  emailsProcessed Int            @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  errorMessage    String?
  createdAt       DateTime       @default(now())
  
  // Snapshot of scheduler settings at the time of execution
  schedulerName   String?
  schedulerType   String?
  schedulerConfig String?         // JSON string with selectedDays and dayTimeSlots at execution time
  
  scheduler       BatchScheduler @relation(fields: [schedulerId], references: [id])
}

model Attachment {
  id            String     @id @default(uuid())
  emailId       String
  userId        String?    // Add user isolation
  fileName      String
  originalFileName String? // Original filename with Thai characters
  fileType      String
  filePath      String
  cloudPath     String?    // Cloud storage path
  cloudProvider String?    // s3, supabase, etc.
  size          Int?
  extractedText String?
  ocrStatus     OcrStatus?
  createdAt     DateTime   @default(now())
  email         Email      @relation(fields: [emailId], references: [id])
  user          User?      @relation(fields: [userId], references: [id])
}

enum OcrStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  ERROR
}

// Add User model for multi-user support
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  emails        Email[]
  emailAccounts EmailAccount[]
  attachments   Attachment[]
  batchSchedulers BatchScheduler[]
}

enum ScheduleType {
  DAILY
  HOURLY
  CUSTOM
}

enum BatchRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
